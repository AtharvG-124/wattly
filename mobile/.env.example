# Wattly Express API
# Simulator: http://localhost:3000 targets Next.js (npm run dev in wattly/web)
# Physical phone: your computer's LAN IP, e.g. http://192.168.1.12:3000 (same Wi‑Fi)
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_DEMO_USER_ID=00000000-0000-0000-0000-000000000001

# Supabase — same project as wattly/web/.env.local
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_1nZVn77yE9ErCjdTkZltqA_v0gH7DNq
