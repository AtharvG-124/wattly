{
  "expo": {
    "name": "Iris",
    "slug": "iris",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "iris",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0a0a0b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.iris.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0b"
      },
      "package": "app.iris.mobile",
      "usesCleartextTraffic": true
    },
    "plugins": ["expo-router"],
    "extra": {
      "apiUrl": "http://localhost:3000"
    }
  }
}
