# --- Browser (public) ---
NEXT_PUBLIC_DEMO_USER_ID=00000000-0000-0000-0000-000000000001
# Optional: only if the Next app and API are on different origins (leave unset for same-origin /api)
# NEXT_PUBLIC_API_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Server (Route Handlers — not exposed to the browser) ---
