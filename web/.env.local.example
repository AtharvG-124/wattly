SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
WATTLY_DEVICE_API_KEY=dev-secret-change-me
DEMO_USER_ID=00000000-0000-0000-0000-000000000001
# SEED_PROTECTED=true
